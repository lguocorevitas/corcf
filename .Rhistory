library(corcf)
ls("package:corcf")
library(corcf)
grep("loading corcf", list.files("R", full.names = TRUE), value = TRUE)
files <- list.files("R", full.names = TRUE)
matches <- sapply(files, function(f) any(grepl("loading corcf", readLines(f, warn = FALSE), fixed = TRUE)))
files[matches]
files <- list.files("R", full.names = TRUE)
for (f in files) {
txt <- readLines(f, warn = FALSE)
hit <- grepl("\\.onLoad|\\.onAttach|library\\(|require\\(", txt)
if (any(hit)) {
cat("\n---", f, "---\n")
cat(paste(which(hit), txt[hit], sep = ": "), sep = "\n")
cat("\n")
}
}
